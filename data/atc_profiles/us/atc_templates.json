{
  "_comment": "ATC response templates for the US/Canada region (FAA / NAV CANADA phraseology). Structure identical to the EU variant: towered/uncontrolled -> ATC state -> pilot intent. Key regional differences: altimeter in inches of mercury (use {altimeter}), taxi clearances include explicit 'hold short' of the destination runway (FAA AIM 4-3-18), CTAF self-announcements repeat the airport name as both prefix and suffix, VFR squawk is 1200, and there are no VRPs (INITIAL_CALL_INBOUND_VRP is intentionally absent). REQUEST_FLIGHT_FOLLOWING is a US-specific VFR advisory service (AIM 4-1-17).",
  "fallbacks": {
    "_comment": "Controller fallback lines for garbled / unclear transmissions. Rendered by engine.cpp::build_unclear_response() with the callsign + ', ' prefixed.",
    "say_again": "say again.",
    "garbled_say_again": "your transmission was garbled, say again.",
    "say_again_use_standard_phraseology": "say again, use standard phraseology."
  },
  "towered": {
    "IDLE": {
      "INITIAL_CALL_GROUND": {
        "response": "{callsign}, {airport} {taxi_controller}, {position_remark}information {atis_letter} current, runway {runway}, altimeter {altimeter}.",
        "next_state": "GROUND_CONTACT",
        "requires_readback": false
      },
      "INITIAL_CALL_TOWER": {
        "response": "{callsign}, {airport} Tower, go ahead.",
        "next_state": "TOWER_CONTACT",
        "requires_readback": false
      },
      "INITIAL_CALL_INBOUND": {
        "response": "{callsign}, {airport} Tower, enter {pattern_direction} downwind runway {runway}, report midfield.",
        "next_state": "Pattern/PATTERN_ENTRY",
        "requires_readback": true
      },
      "REQUEST_TAXI": {
        "response": "{callsign}, {airport} {taxi_controller}, {position_remark}information {atis_letter} current, runway {runway}, taxi via Alpha, hold short runway {runway}, altimeter {altimeter}.",
        "next_state": "TAXI_CLEARED",
        "requires_readback": true
      },
      "REQUEST_TAXI_PARKING": {
        "response": "{callsign}, {airport} {taxi_controller}, taxi to the ramp via Alpha.",
        "next_state": "IDLE",
        "requires_readback": true
      },
      "READBACK": {
        "response": "",
        "next_state": "IDLE",
        "requires_readback": false
      },
      "READY_FOR_DEPARTURE": {
        "response": "{callsign}, {airport} Tower, runway {runway}, cleared for takeoff, wind {wind}, {pattern_direction} closed traffic approved.",
        "next_state": "Pattern/DEPARTURE_CLEARED",
        "requires_readback": true
      },
      "READY_FOR_DEPARTURE_VFR": {
        "response": "{callsign}, {airport} Tower, runway {runway}, cleared for takeoff, wind {wind}, on course approved, frequency change approved.",
        "next_state": "XC/DEPARTURE_CLEARED",
        "requires_readback": true
      },
      "RADIO_CHECK": {
        "response": "{callsign}, {airport} Tower, loud and clear.",
        "next_state": "IDLE",
        "requires_readback": false
      },
      "INITIAL_CALL_APPROACH": {
        "response": "{callsign}, {airport} Approach, go ahead.",
        "next_state": "XC/APPROACH_CONTACT",
        "requires_readback": false
      },
      "REQUEST_FLIGHT_FOLLOWING": {
        "response": "{callsign}, {airport} Approach, squawk 4527, ident, say altitude.",
        "next_state": "XC/APPROACH_CONTACT",
        "requires_readback": true
      },
      "RUNWAY_VACATED": {
        "response": "{callsign}, roger, contact Ground on {ground_frequency}, good day.",
        "next_state": "IDLE",
        "requires_readback": false
      },
      "RUNWAY_VACATED_TOWER_ONLY": {
        "response": "{callsign}, roger, taxi to the ramp via Alpha, good day.",
        "next_state": "IDLE",
        "requires_readback": false
      },
      "_INVALID": {
        "response": "{callsign}, say again.",
        "next_state": "IDLE",
        "requires_readback": false
      }
    },
