{
  "_comment": "Data-driven intent classification rules for DE/BZF phraseology. Loaded by src/atc/intent_rules.cpp. Schema: see intent_rules.hpp. DE-Region-specific rules: additive to EN keywords so BZF transcripts with mixed EN/DE words ('Friedrichshafen Tower' / 'in sight') still classify. Note: intent_parser::parse() runs de_phraseology::parse_spoken_number() before this layer, so ziffernweise BZF pronunciation ('eins null eins drei') already arrives as raw digits ('1013') -- rules below match on numeric form.",

  "normalize": [],

  "rules": [
    {
      "_note": "Profanity / insults toward ATC. Highest priority so tone is caught even when other intent keywords are present.",
      "intent": "INAPPROPRIATE_LANGUAGE",
      "confidence": 0.99,
      "any": [
        "fuck", "shit", "bullshit", "asshole", "bitch", "bastard",
        "damn it", "dammit", "piss off", "piss on", "dick head", "dickhead",
        "mother", "wanker", "cunt",
        "scheiss", "scheiße", "arschloch", "hurensohn", "wichser",
        "fick", "verdammte", "drecks", "vollidiot", "depp",
        { "all": [
            { "any": ["idiot", "stupid", "moron", "incompetent", "useless",
                      "dumm", "bloed", "blöd", "unfaehig", "unfähig"] },
            { "any": ["you", "tower", "ground", "controller", "atc",
                      "turm", "boden", "lotse", "fluglotse"] }
        ]}
      ]
    },

    {
      "_note": "Pilot-issued correction phraseology. 'negativ' alone is BZF's 'no'; 'negativer kontakt' is a traffic-advisory reply and must NOT be claimed here.",
      "intent": "NEGATIVE_CORRECTION",
      "confidence": 0.95,
      "none": ["negative contact", "no contact", "negativer kontakt", "kein kontakt"],
      "any": [
        { "starts_with": "negative" },
        { "starts_with": "negativ" },
        ", negative",
        ", negativ",
        { "starts_with": "correction" },
        { "starts_with": "berichtige" },
        { "starts_with": "berichtigung" },
        ", correction",
        ", berichtigung",
        { "starts_with": "no correction" },
        { "starts_with": "no, correction" },
        "disregard",
        "vergessen sie",
        "vergiss das",
        "that's wrong",
        "that is wrong",
        "that's incorrect",
        "that is incorrect",
        "das ist falsch",
        "i meant",
        "ich meinte",
        "ich sagte",
        "i said",
        "cancel that",
        "cancel my last",
        "negative on",
        "negative that"
      ]
    },

    { "intent": "UNABLE",      "confidence": 0.95, "any": ["unable", "nicht moeglich", "nicht möglich"] },
    { "intent": "RADIO_CHECK", "confidence": 0.95, "any": ["radio check", "how do you read", "funkpruefung", "funkprüfung", "funkprobe", "wie hoeren sie mich", "wie hören sie mich"] },
    { "intent": "REQUEST_REPEAT", "confidence": 0.95, "any": ["wiederholen sie", "sagen sie nochmals", "sagen sie noch einmal", "say again", "noch einmal bitte", "noch mal bitte"] },
    { "intent": "GO_AROUND",   "confidence": 0.95, "any": ["going around", "go around", "missed approach", "durchstarten", "durchstart", "fehlanflug"] },

    {
      "_note": "Pilot-initiated frequency change announcement.",
      "intent": "LEAVING_FREQUENCY",
      "confidence": 0.85,
      "any": [
        "leaving your frequency",
        "leaving frequency",
        "signing off",
        "verlasse ihre frequenz",
        "verlasse die frequenz",
        "auf wiederhoeren",
        "auf wiederhören",
        { "any": ["frequency change", "change frequency", "frequenzwechsel"],
          "none": ["request", "approved", "erbitte", "genehmigt"] }
      ]
    },

    {
      "_note": "Traffic-advisory replies must come BEFORE SELF_ANNOUNCE.",
      "intent": "TRAFFIC_IN_SIGHT",
      "confidence": 0.92,
      "any": ["traffic in sight", "in sight", "verkehr in sicht", "in sicht"]
    },
    {
      "intent": "TRAFFIC_NEGATIVE_CONTACT",
      "confidence": 0.92,
      "any": ["negative contact", "no contact", "negativer kontakt", "kein kontakt", "kein verkehr"]
    },

    { "intent": "SELF_ANNOUNCE", "confidence": 0.90, "any": ["traffic", "verkehr"] },

    {
      "_note": "Readback. DE phrases: 'verstanden', 'rollen Sie' (ATC instruction echo), 'Rollhalt'/'Haltepunkt', 'kontaktiere', 'Startfreigabe'/'Landefreigabe'. Also the compact Tower echo phrases 'Start frei' (take-off clearance readback) and 'Landung frei' (landing clearance readback) — Whisper renders the Tower's wording verbatim, so the pilot's repeat-back shows up as the same short tokens. A post-landing adjustment below demotes 'Landung frei' to RUNWAY_VACATED when at_airport_after_landing fires.",
      "intent": "READBACK",
      "confidence": 0.90,
      "any": [
        "wilco",
        "roger",
        "verstanden",
        "contact ground",
        "contact tower",
        "contact approach",
        "contact departure",
        "kontaktiere boden",
        "kontaktiere turm",
        "kontaktiere anflug",
        "goodbye",
        "good bye",
        "good day",
        "see you",
        "auf wiederhoeren",
        "auf wiederhören",
        "control zone",
        "control-zone",
        "kontrollzone",
        "into the zone",
        "in die zone",
        "cleared into",
        "cleared to enter",
        "freigegeben in die",
        "joining instructions",
        "joining the",
        "holding point",
        "hold short",
        "qnh",
        "hold position",
        "halte position",
        "position halten",
        "landung frei",
        "start frei",
        { "all": ["rollen sie", { "any": ["ueber", "über", "via"] }] },
        { "all": ["rollen sie", { "any": ["haltepunkt", "rollhalt"] }] },
        { "all": ["taxi", " via "] },
        { "all": [
            { "any": ["cleared", "clear for", "clear to",
                      "freigegeben", "freigabe zum"] },
            { "any": ["takeoff", "take off", "take of", "land",
                      "start", "landung"] }
        ]},
        { "all": [
            { "any": ["startfreigabe", "landefreigabe"] }
        ]},
        { "all": [
            "on course",
            { "any": ["approved", "approve"] }
        ]},
        { "all": [
            { "any": ["frequency change", "change frequency", "frequenzwechsel"] },
            { "any": ["approved", "when airborne", "genehmigt"] }
        ]},
        { "all": [
            { "any": ["takeoff", "take off", "departure", "abflug"] },
            { "any": ["report", "melden", "melde"] }
        ]},
        { "all": [
            { "any": ["downwind", "base", "final",
                      "gegenanflug", "queranflug", "endanflug"] },
            { "any": ["report", "melden", "melde"] }
        ]},
        { "ends_with": " left" },
        { "ends_with": " right" },
        { "ends_with": " center" },
        { "ends_with": " links" },
        { "ends_with": " rechts" },
        { "ends_with": " mitte" },
        { "ends_with_runway_token": true }
      ]
    },

    {
      "_note": "VFR cross-country departure: ready-for-departure plus a course/direction marker.",
      "intent": "READY_FOR_DEPARTURE_VFR",
      "confidence": 0.92,
      "all": [
        { "any": ["ready", "bereit", "abflugbereit", "startbereit"] },
        { "any": ["departure", "takeoff", "take off", "holding short",
                  "abflug", "warteposition", "rollhalt", "haltepunkt"] },
        { "any": ["on course", "en route", "en-route", "enroute",
                  "northbound", "southbound", "eastbound", "westbound",
                  "vfr to", "departure to the", "cross country", "cross-country",
                  "nach norden", "nach sueden", "nach süden",
                  "nach osten", "nach westen",
                  "nordkurs", "suedkurs", "südkurs", "ostkurs", "westkurs",
                  "ueberlandflug", "überlandflug",
                  "nach"] }
      ]
    },

    {
      "intent": "READY_FOR_DEPARTURE",
      "confidence": 0.90,
      "all": [
        { "any": ["ready", "bereit", "abflugbereit", "startbereit"] },
        { "any": ["departure", "takeoff", "take off", "holding short",
                  "abflug", "warteposition", "rollhalt", "haltepunkt"] }
      ]
    },

    {
      "intent": "REQUEST_TOUCH_AND_GO",
      "confidence": 0.90,
      "any": ["touch and go", "durchstartlandung", "durchstart und landung", "aufsetzen und durchstarten"],
      "none": ["taxi", "rollen"]
    },

    {
      "_note": "Parking/apron/etc. as the destination -- NOT pilot's location.",
      "intent": "REQUEST_TAXI_PARKING",
      "confidence": 0.90,
      "any": [
        "taxi to parking", "taxi to the parking",
        "taxi to apron", "taxi to the apron",
        "taxi to general aviation",
        "taxi to stand", "taxi to gate",
        "taxi to the ramp", "taxi to ramp",
        "rollen zur abstellposition", "rollen zum vorfeld",
        "rollen zum abstellplatz", "rollen zur ga"
      ]
    },

    {
      "_note": "Runway-vacated. DE: 'Piste frei' (free), 'Piste verlassen' (left), 'Piste geraeumt' (cleared). Pilots in real BZF traffic say 'Piste 06 frei' with the runway number in between, so we also accept 'piste' + 'frei' as separate tokens. 'landung'/'start' guards keep the Tower-echo readbacks ('Landung frei', 'Start frei') out — those are handled by READBACK above.",
      "intent": "RUNWAY_VACATED",
      "confidence": 0.90,
      "any": [
        "vacated",
        "piste frei",
        "piste verlassen",
        "piste geraeumt",
        "piste geräumt",
        "habe die piste verlassen",
        { "all": ["piste", "frei"],
          "none": ["landung", "start"] },
        { "all": ["piste", "verlassen"],
          "none": ["landung", "start"] },
        { "all": ["clear", "runway"],
          "none": ["for take", "takeoff", "landing", "land"] },
        { "all": ["left", "runway"], "none": ["downwind", "base", "gegenanflug", "queranflug"] }
      ]
    },

    {
      "_note": "Plain 'request taxi' / 'rollen'. Exclude clearance readbacks ('rollen sie ueber X') and frequency-change readbacks that mention 'taxi'.",
      "intent": "REQUEST_TAXI",
      "confidence": 0.90,
      "any": ["taxi", "request taxi", "taxiing", "rollen", "rollfreigabe", "erbitte rollen"],
      "none": [
        "contact ground", "contact tower", "contact approach", "contact departure",
        "kontaktiere boden", "kontaktiere turm", "kontaktiere anflug",
        { "all": ["taxi", "holding point"] },
        { "all": ["taxi", "hold short"] },
        { "all": ["taxi", " via "] },
        { "all": ["taxi", "qnh"] },
        { "all": ["taxi", "hold position"] },
        { "all": ["rollen sie", "haltepunkt"] },
        { "all": ["rollen sie", "rollhalt"] },
        { "all": ["rollen sie", "ueber"] },
        { "all": ["rollen sie", "über"] },
        { "all": ["rollen", "qnh"] }
      ]
    },

    {
      "_note": "Position-Reports. 'melden sie' (Tower-Imperativ) und 'report' (EN-Imperativ) ausschliessen, damit der Pilot-Readback der Anweisung 'melden Sie Gegenanflug/Endanflug' nicht falsch als Position-Report klassifiziert wird. Echo der Tower-Anweisung gehoert zu READBACK.",
      "intent": "REPORT_POSITION_DOWNWIND",
      "confidence": 0.90,
      "all": [{ "any": ["downwind", "gegenanflug"] }],
      "none": ["takeoff", "take off", "abflug", "melden sie", "report"]
    },
    {
      "intent": "REPORT_POSITION_BASE",
      "confidence": 0.90,
      "all": [{ "any": ["base", "queranflug"] }],
      "none": ["base leg to final", "melden sie", "report"]
    },
    {
      "intent": "REPORT_POSITION_FINAL",
      "confidence": 0.93,
      "all": [{ "any": ["final", "endanflug"] }],
      "none": ["full stop", "voller halt", "melden sie", "report"]
    },
    {
      "intent": "REPORT_POSITION",
      "confidence": 0.85,
      "any": ["crosswind", "upwind", "rueckenwind", "rückenwind"]
    },

    {
      "_note": "Inbound/landing request, but only when no facility keyword (Tower/Turm/Approach/Anflug) is present.",
      "intent": "REQUEST_LANDING",
      "confidence": 0.93,
      "any": ["inbound", "landing", "full stop", "zur landung", "voller halt"],
      "none": [
        "touch and go",
        "durchstartlandung",
        "aufsetzen und durchstarten",
        { "has_facility": "tower" },
        { "has_facility": "turm" },
        { "has_facility": "approach" },
        { "has_facility": "anflug" }
      ]
    },

    {
      "_note": "US-specific VFR advisory service.",
      "intent": "REQUEST_FLIGHT_FOLLOWING",
      "confidence": 0.92,
      "any": ["flight following", "vfr advisory", "radar service", "flight follow"]
    },

    {
      "intent": "REQUEST_FREQUENCY",
      "confidence": 0.80,
      "any": [
        "request frequency",
        "request a frequency",
        "request to leave",
        "with you",
        "switching",
        "erbitte frequenz",
        "erbitte frequenzwechsel"
      ]
    },

    {
      "_note": "Approach Control / Radar. DE 'Anflugkontrolle' shortened to 'Anflug'.",
      "intent": "INITIAL_CALL_APPROACH",
      "confidence": 0.88,
      "any": [
        { "has_facility": "approach" },
        { "has_facility": "radar" },
        { "has_facility": "anflug" },
        { "has_facility": "anflugkontrolle" }
      ],
      "none": [
        "continue approach", "final approach", "missed approach",
        "short approach", "straight-in approach", "straight in approach",
        "on approach", "abandon approach", "cleared approach",
        "cleared for the approach",
        "im endanflug", "endanflug", "abgebrochener anflug"
      ]
    },

    {
      "intent": "INITIAL_CALL_GROUND",
      "confidence": 0.85,
      "any": [
        { "has_facility": "ground" },
        { "has_facility": "delivery" },
        { "has_facility": "boden" },
        { "has_facility": "rollkontrolle" },
        { "has_facility": "freigabe" }
      ]
    },

    {
      "_note": "Tower call with inbound/landing intent -- beats INITIAL_CALL_TOWER below.",
      "intent": "INITIAL_CALL_INBOUND",
      "confidence": 0.85,
      "all": [
        { "any": [
            { "has_facility": "tower" },
            { "has_facility": "turm" }
        ] }
      ],
      "any": ["inbound", "landing", "full stop", "zur landung", "voller halt"]
    },

    {
      "intent": "INITIAL_CALL_TOWER",
      "confidence": 0.85,
      "any": [
        { "has_facility": "tower" },
        { "has_facility": "turm" }
      ]
    },

    {
      "_note": "Generic initial call -- last resort.",
      "intent": "INITIAL_CALL",
      "confidence": 0.80,
      "any": [
        { "has_facility": "ground" },
        { "has_facility": "delivery" },
        { "has_facility": "tower" },
        { "has_facility": "boden" },
        { "has_facility": "turm" },
        { "has_facility": "rollkontrolle" },
        { "has_facility": "freigabe" }
      ]
    },

    {
      "_note": "Last-resort fallback for traffic-advisory replies. Single keyword 'looking' / 'halte ausschau' is ambiguous; confidence is low.",
      "intent": "TRAFFIC_LOOKING",
      "confidence": 0.70,
      "any": ["looking", "halte ausschau", "suche verkehr"]
    }
  ],

  "adjustments": [
    {
      "_note": "Upgrade INITIAL_CALL_INBOUND -> INITIAL_CALL_INBOUND_VRP when a VRP was named.",
      "if": { "intent": "INITIAL_CALL_INBOUND", "vrp_name_set": true },
      "set_intent": "INITIAL_CALL_INBOUND_VRP"
    },
    {
      "_note": "Airborne intent while on ground -- likely a readback. Demote to READBACK.",
      "if": { "intent_is_airborne_only": true, "on_ground": true },
      "set_intent": "READBACK",
      "set_confidence": 0.85
    },
    {
      "_note": "Ground intent while airborne -- physically impossible.",
      "if": { "intent_is_ground_only": true, "on_ground": false },
      "set_confidence": 0.3
    },
    {
      "_note": "SELF_ANNOUNCE only makes sense on UNICOM at non-towered fields.",
      "if": { "intent": "SELF_ANNOUNCE", "is_towered": true },
      "set_confidence": 0.3
    },
    {
      "_note": "Pilot called 'tower' at a non-towered airport -- phraseology error.",
      "if": { "intent_in": ["INITIAL_CALL", "INITIAL_CALL_TOWER", "INITIAL_CALL_INBOUND"],
              "is_towered": false, "text_contains": "tower" },
      "set_confidence": 0.4
    },
    {
      "_note": "DE counterpart: pilot called 'turm' at a non-towered airport.",
      "if": { "intent_in": ["INITIAL_CALL", "INITIAL_CALL_TOWER", "INITIAL_CALL_INBOUND"],
              "is_towered": false, "text_contains": "turm" },
      "set_confidence": 0.4
    },
    {
      "_note": "Post-landing 'request taxi' / 'rollen' is a taxi-to-apron request as long as the pilot is still in the post-landing state window (on the ground, last landing in history, no new DEPARTURE_CLEARED yet). State window instead of the 120 s just_landed clock so a long roll-out plus slow taxi-back still hits the demotion. Mirrors the at_airport_after_landing choice in the 'Landung frei' demote rule below.",
      "if": { "intent": "REQUEST_TAXI", "require_context_flag": "at_airport_after_landing" },
      "set_intent": "REQUEST_TAXI_PARKING"
    },
    {
      "_note": "Post-landing Whisper mishearing: the Tower's 'Landung frei' clearance bleeds into the audio context and Whisper renders the pilot's 'Piste frei' vacated call as 'Landung frei' instead. While we are on the ground after a landing without a new departure cycle, treat the READBACK match on 'landung frei' as a fumbled vacated report and demote to RUNWAY_VACATED. State window (at_airport_after_landing) instead of the 120 s just_landed clock so a long roll-out plus taxi-back to a far exit still hits the demotion.",
      "if": { "intent": "READBACK", "text_contains": "landung frei",
              "require_context_flag": "at_airport_after_landing" },
      "set_intent": "RUNWAY_VACATED"
    },
    {
      "_note": "RUNWAY_VACATED is physically impossible without a prior airborne phase. STT often drops 'start' from 'Piste 06 startfrei' (the departure readback) -- with a readback pending, the malformed 'piste frei' was almost certainly the readback the pilot meant. Remap so the tower silently accepts it instead of looping the readback-reminder.",
      "if": { "intent": "RUNWAY_VACATED", "was_airborne": false, "readback_pending": true },
      "set_intent": "READBACK"
    },
    {
      "_note": "Same physical impossibility (RUNWAY_VACATED without ever being airborne), but no readback pending -- demote confidence to 0.0 so the engine routes the utterance through the LM classify-with-repair path instead of forcing the vacated rule.",
      "if": { "intent": "RUNWAY_VACATED", "was_airborne": false, "readback_pending": false },
      "set_confidence": 0.0
    }
  ]
}
